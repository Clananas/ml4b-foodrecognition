# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/

# --- Virtual environment ---
.venv/

# --- Large model weights (re-downloaded on first use) ---
models/

# --- Datasets (downloaded on demand by scripts in data/) ---
# Comments must NOT be on the same line as the pattern, otherwise git
# treats the whole line including the comment as one pattern.
data/ECUSTFD/
data/Nutrition5k/
data/*.zip
data/own_dataset/

# --- Build artifacts that aren't useful to share ---
artifacts/*.png

# Trained models and cached features ARE committed — they let the app run
# immediately after a clone, and they document the latest training result.

# --- OS / editor ---
.DS_Store
.vscode/
.idea/
