# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/

# --- Virtual environment ---
.venv/

# --- Large model weights (re-downloaded on first use) ---
models/

# --- Datasets (downloaded on demand) ---
data/ECUSTFD/                          # ~125 MB, fetched by data/download_ecustfd.py
data/Nutrition5k/                      # ~162 MB, fetched by data/download_nutrition5k.py
data/*.zip
data/own_dataset/

# --- Build artifacts that aren't useful to share ---
artifacts/*.png

# Trained models and cached features ARE committed — they let the app run
# immediately after a clone, and they document the latest training result.
# Override if a single file ever grows large:
#   artifacts/some_huge_file.bin

# --- OS / editor ---
.DS_Store
.vscode/
.idea/
